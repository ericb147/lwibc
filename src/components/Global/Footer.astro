              </div>
            )
          }
        </div> -->

        <div class="mt-4 text-gray-300">
          <h4 class="text-sm font-bold mb-2 text-white">Service Times</h4>
          {
          <div class="text-sm">
            <p><strong class="text-white">Sunday Morning:</strong> 11:00 AM</p>
            <p><strong class="text-white">Wednesday Night:</strong> 7:00 PM</p>
          </div>
            
          }
        </div>
        
        <!-- Social Links -->
        <div class="flex space-x-4 mt-6">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white transition-colors"
                aria-label={link.name}
              >
                <Fragment set:html={link.icon} />
              </a>
            ))
            
          }
          
        </div>
      </div>
      
      <!-- Navigation Links -->
      {
        footerNavs.map((group) => (
          <div>
            <h4 class="text-lg font-bold mb-4 text-white">{group.title}</h4>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li>
                  <a 
                    href={item.href} 
                    class="text-gray-300 hover:text-primary-300 transition-colors"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    
    <!-- Copyright -->
    <div class="pt-8 mt-8 border-t border-gray-800 text-center text-gray-400 text-sm">
      <p>&copy; {currentYear} Living Waters Independent Baptist Church. All rights reserved.</p>
      <p class="mt-2">
        Created by 
        <a href="https://www.ericblankenship.dev" class="hover:text-primary-300 mr-4">ericblankenship.dev</a>
      </p>
    </div>
  </div>
</footer>