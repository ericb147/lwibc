---
import { getCollection } from "astro:content";
import Logo from "../UI/Logo.astro";

// Get the office hours from the siteInfo collection
let officeHours;
try {
  const siteInfoEntries = await getCollection("siteInfo");
  officeHours = siteInfoEntries.find(entry => entry.id === "office-hours");
} catch (error) {
  // Collection might not exist yet when first setting up the project
  console.log("Office hours not found or collections not yet available");
}

// Footer navigation groups
const footerNavs = [
  {
    title: "About",
    items: [
      { text: "About Us", href: "/about-us" },
      { text: "I'm New", href: "/im-new" },
      { text: "Staff", href: "/staff" },
      { text: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Resources",
    items: [
      { text: "Sermons", href: "/sermons" },
      { text: "Events", href: "/events" },
      { text: "Blog", href: "/blog" },
      { text: "Ministries", href: "/ministries" },
    ],
  },
  {
    title: "Connect",
    items: [
      { text: "Giving", href: "/giving" },
      { text: "Prayer Request", href: "/contact#prayer" },
      { text: "Newsletter", href: "/contact#newsletter" },
      { text: "Volunteer", href: "/im-new#volunteer" },
    ],
  },
];

// Social media links
const socialLinks = [
  { 
    name: "Facebook",
    href: "https://facebook.com/yourchurch", 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>` 
  },
  { 
    name: "Instagram", 
    href: "https://instagram.com/yourchurch", 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>` 
  },
  { 
    name: "YouTube", 
    href: "https://youtube.com/yourchurch", 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>` 
  },
];

// Current year for copyright
const currentYear = new Date().getFullYear();

// Render office hours content if available
let OfficeHoursContent = null;
if (officeHours) {
  const { Content } = await officeHours.render();
  OfficeHoursContent = Content;
}
---
<footer class="bg-gray-950 text-gray-300 pt-20 pb-10 border-t-4 border-primary-900">
  <div class="container mx-auto px-4">
    
    <div class="flex flex-col items-center text-center mb-16">
      <Logo class="h-28 w-28 text-primary-800 mb-6" width="112" height="112" title="LWIBC" />
      <h2 class="text-3xl md:text-4xl font-serif text-white italic tracking-wide">
        Living Waters
      </h2>
      <div class="flex items-center gap-4 w-full max-w-md my-4">
        <div class="h-px bg-gray-800 flex-grow"></div>
        <span class="text-xs uppercase tracking-[0.3em] text-primary-500 font-bold">Independent Baptist Church</span>
        <div class="h-px bg-gray-800 flex-grow"></div>
      </div>
      <p class="font-serif text-lg text-gray-400">Preaching the Word, Reaching the World.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 text-center md:text-left border-t border-gray-900 pt-12">
      
      <div>
        <h4 class="font-serif text-xl text-white mb-6 italic">Location & Contact</h4>
        <address class="not-italic space-y-3 text-sm">
          <p class="hover:text-white transition-colors">7561 Duncan Gap Rd.<br />Wise, VA 24293</p>
          <p class="pt-2">
            <a href="tel:+12766397708" class="text-primary-400 hover:text-primary-300 font-bold">(276) 639-7708</a>
          </p>
          <p>
            <a href="mailto:livingwatersibc@gmail.com" class="hover:text-white break-all">livingwatersibc@gmail.com</a>
          </p>
        </address>
      </div>

      {footerNavs.map((group) => (
        <div>
          <h4 class="font-serif text-xl text-white mb-6 italic">{group.title}</h4>
          <ul class="space-y-3 text-sm">
            {group.items.map((item) => (
              <li>
                <a href={item.href} class="hover:text-primary-400 transition-colors">
                  {item.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-20 pt-8 border-t border-gray-900 flex flex-col items-center gap-6">
      <div class="flex space-x-6">
        {socialLinks.map((link) => (
          <a href={link.href} class="p-2 rounded-full border border-gray-800 hover:border-primary-700 hover:bg-primary-900/20 text-gray-400 hover:text-white transition-all">
            <Fragment set:html={link.icon} />
          </a>
        ))}
      </div>
      
      <div class="text-center text-xs tracking-wide text-gray-500">
        <p>&copy; {currentYear} Living Waters Independent Baptist Church. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>