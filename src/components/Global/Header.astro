---
import Navigation from "./Navigation.astro";
import Logo from "../UI/Logo.astro";
---

<header class="sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md shadow-sm">
  <div class="container flex items-center justify-between h-20">
    <a href="/" class="group text-2xl font-bold text-primary-800 font-serif flex items-center">
      <span class="sr-only">LWIBC Logo</span>
      
      {/* Added transition classes:
         - transition-transform: prepares it for moving
         - duration-300: makes it smooth
         - group-hover:scale-110: makes it slightly larger on hover
      */}
      <Logo 
        class="h-12 w-auto text-primary-800 mr-2 transition-transform duration-300 group-hover:scale-110" 
        width="48" 
        height="48" 
        title="LWIBC" 
      />
      
      <span class="text-primary-800">LWIBC</span>
    </a>
    
    <Navigation />
  </div>
</header>