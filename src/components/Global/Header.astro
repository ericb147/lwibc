---
import Navigation from "./Navigation.astro";
import Logo from "../UI/Logo.astro";
---

<header class="sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md shadow-sm">
  <div class="container flex items-center justify-between h-20">
    <a href="/" class="text-2xl font-bold text-primary-800 font-serif flex items-center">
      <span class="sr-only">LWIBC Logo</span>
      <Logo class="h-12 w-auto text-primary-800 mr-2" width="48" height="48" title="LWIBC" />
      <span class="text-primary-800">LWIBC</span>
    </a>
    
    <Navigation />
  </div>
</header>