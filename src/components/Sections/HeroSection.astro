---
import Button from "../UI/Button.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  backgroundVideos?: string[];
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  title = "Welcome to Living Waters Independent Baptist Church",
  subtitle = "Preaching the Word. Proclaiming the Gospel.",
  backgroundVideos = ["/uploads/preaching.mp4"],
  ctaText = "Plan Your Visit",
  ctaLink = "/im-new",
  secondaryCtaText = "Watch Sermons",
  secondaryCtaLink = "/sermons",
} = Astro.props;
---
<section class="relative min-h-[70vh] flex items-center pt-30 overflow-hidden">
  <!-- video carousel background -->
  <div data-video-carousel class="absolute inset-0">
    {backgroundVideos.map((src, i) => (
      <video
        aria-hidden="true"
        autoplay
        muted
        loop
        playsinline
        class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ease-in-out ${i === 0 ? "opacity-100" : "opacity-0 pointer-events-none"}`}
      >
        <source src={src} type="video/mp4" />
      </video>
    ))}
  </div>

  <!-- overlay to replicate previous gradient -->
  <div class="absolute inset-0 bg-black/60"></div>

  <!-- optional controls -->
  {backgroundVideos.length > 1 && (
    <>
      <button data-prev class="absolute left-4 top-1/2 -translate-y-1/2 z-20 p-2 bg-black/30 text-white rounded-md">
        ‹
      </button>
      <button data-next class="absolute right-4 top-1/2 -translate-y-1/2 z-20 p-2 bg-black/30 text-white rounded-md">
        ›
      </button>
    </>
  )}

  <div class="container relative z-10">
    <div class="max-w-3xl text-white">
      <h1 class="text-4xl md:text-6xl font-bold mb-4 text-white">{title}</h1>
      <p class="text-xl md:text-2xl mb-8">{subtitle}</p>
      
      <div class="flex flex-wrap gap-4">
        <Button href={ctaLink} variant="primary" size="lg">
          {ctaText}
        </Button>
        
        <Button href={secondaryCtaLink} variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
          {secondaryCtaText}
        </Button>
      </div>
    </div>
  </div>
</section>

<!-- load client script (put new file at /public/scripts/video-carousel.js) -->
<script type="module" src="/scripts/video-carousel.js" defer></script>