---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import EventList from "../components/Sections/EventList.astro";
import SermonList from "../components/Sections/SermonList.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout>
  <HeroSection/>
  
  <!-- Service Times -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Join Us!</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold mb-3">Sunday Morning Service</h3>
            <p class="text-2xl font-bold text-primary-600 mb-2">11:00 AM</p>
            <!-- <p class="text-gray-600 mb-4">|Describe Service Here|</p>
            <p class="italic text-gray-500">In-person & Youtube Video</p> -->
          </div>
          
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold mb-3">Wednesday Night Bible Study</h3>
            <p class="text-2xl font-bold text-primary-600 mb-2">7:00 PM</p>
            <!-- <p class="text-gray-600 mb-4">|Describe Service Here|</p>
            <p class="italic text-gray-500">In-person only</p> -->
          </div>
        </div>
        
        <Button href="/im-new" variant="outline">
          Plan Your Visit
        </Button>
      </div>
    </div>
  </section>
  
  <!-- About Section -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <img 
            src="/uploads/church-building.jpeg" 
            alt="Our Church" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
        
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">About Our Church</h2>
          <p class="text-gray-700 mb-6 text-lg">
            We are a local Independent Baptist congregation whose goal is to spread the Gospel message of Jesus Christ through the preaching and singing of the King James Bible.
          </p>
          <p class="text-gray-700 mb-8 text-lg">
            Our desire is to help people discover a personal relationship with Jesus Christ, to help them grow deeper in that relationship, and to equip them to live a life that exalts Jesus Christ and points others to that same kind of relationship with Him.
          </p>
          
          <Button href="/about-us">
            Learn More About Us
          </Button>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Events Section -->
  <EventList />
  
  <!-- Sermons Section -->
  <SermonList />
  
  <!-- Ministries Preview -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Ministries</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Discover how you can connect, serve, and grow through our various ministries
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="card text-center p-8">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <img src="/uploads/childrens-ministry-icon.png" alt="Children's Ministry" class="w-14 h-14" />
          </div>
          <h3 class="text-xl font-bold mb-3">Children's Ministry</h3>
          <p class="text-gray-700 mb-4">
            Nurturing the spiritual growth of our children through engaging, age-appropriate activities.
          </p>
          <a href="/ministries/childrens-ministry" class="text-primary-600 font-medium hover:text-primary-700">
            Learn More →
          </a>
        </div>
        
        <div class="card text-center p-8">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-accent-100 flex items-center justify-center">
            <img src="/uploads/mens-ministry-icon.png" alt="Men's Ministry" class="w-14 h-14" />
          </div>
          <h3 class="text-xl font-bold mb-3">Men's Ministry</h3>
          <p class="text-gray-700 mb-4">
            Empowering men to grow in faith, build meaningful connections, and live out their calling in Christ.
          </p>
          <a href="/ministries/mens-ministry" class="text-primary-600 font-medium hover:text-primary-700">
            Learn More →
          </a>
        </div>
        
        <div class="card text-center p-8">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-secondary-100 flex items-center justify-center">
            <img src="/uploads/womens-ministry-icon.png" alt="Women's Ministry" class="w-14 h-14" />
          </div>
          <h3 class="text-xl font-bold mb-3">Women's Ministry</h3>
          <p class="text-gray-700 mb-4">
            Supporting women in their spiritual journey through fellowship, study, and service opportunities.
          </p>
          <a href="/ministries/womens-ministry" class="text-primary-600 font-medium hover:text-primary-700">
            Learn More →
          </a>
        </div>
      </div>
      
      <div class="mt-12 text-center">
        <Button href="/ministries" variant="outline">
          View All Ministries
        </Button>
      </div>
    </div>
  </section>
  
  <!-- Call to Action -->
  <section 
    class="py-20 bg-cover text-white"
    style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(/uploads/pexels-dom-gould-105501-325807.jpg); background-position: center 70%;"
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Ready to Visit?</h2>
        <p class="text-xl mb-8">
          We'd love to welcome you to our church family. Come visit us this Sunday or reach out with any questions.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/im-new" variant="primary" size="lg">
            I'm New Here
          </Button>
          
          <Button href="/contact" variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>
  
</BaseLayout>