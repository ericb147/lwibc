---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="I'm New - Living Waters Independent Baptist Church"
  description="Everything you need to know about visiting our church for the first time. Find service times, what to expect, and how to get connected."
>
  <PageHeader 
    title="I'm New Here" 
    subtitle="Welcome! We're glad you're considering a visit."
    backgroundImage="/uploads/im-new.jpg"
  />

  
  <!-- What to Expect -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What to Expect</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Here's what you can expect when you visit us for the first time
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Service Length</h3>
          <p class="text-gray-700">
            Our services typically last about 1 hour, including worship, announcements, and the sermon.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Worship Style</h3>
          <p class="text-gray-700">
            We feature traditional hymns led by piano, guitar, and bass, along with featured special music.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Preaching Style</h3>
          <p class="text-gray-700">
            Sunday morning services feature old-fashioned preaching from the King James Bible. Wednesday night services are more of a group Bible study format where we discuss the text together.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- What to Wear -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <img 
            src="uploads/church_dress.avif" 
            alt="Casual church attire" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
        
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">What to Wear</h2>
          <p class="text-gray-700 mb-6 text-lg">
            We want you to feel comfortable when you visit. You'll find people dressed in everything from casual (jeans and t-shirts) to business casual (slacks and button-ups or dresses).
          </p>
          <p class="text-gray-700 mb-6 text-lg">
            Our priority is that you join us, not what you wear. Come as you are, and know you'll be welcomed warmly!
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Service Times -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Service Times</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Join us for worship at any of our weekly services
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <h3 class="text-xl font-bold mb-3">Sunday Morning Service</h3>
          <div class="mb-4">
            <p class="text-2xl font-bold text-primary-600 mb-2">11:00 AM</p>
            <p class="text-gray-600">Traditional preaching service from the King James Bible. This service is more of a "camp meeting" type of atmosphere.</p>
            <p class="italic text-gray-500 mt-2">In-person & YouTube video</p>
          </div>
          
          
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <h3 class="text-xl font-bold mb-3">Wednesday Night Bible Study</h3>
          <div class="mb-4">
            <p class="text-2xl font-bold text-primary-600 mb-2">7:00 PM</p>
            <p class="text-gray-600">In this service, we move through a specific text to exposit and discuss the Word of God together.</p>
            <p class="italic text-gray-500 mt-2">In-person only</p>
          </div>
          
          
        </div>
      </div>
    </div>
  </section>
  
  <!-- For Kids -->
  <section id="kids" class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">For Families with Children</h2>
          <p class="text-gray-700 mb-6 text-lg">
            We love children and believe they are an important part of our church family. Here's what we offer for kids:
          </p>
          
          <ul class="space-y-4 mb-6">
            <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">
                <strong>Nursery:</strong> We provide a clean, quiet nursery and a private room for nursing mothers. For your convenience, both spaces are equipped with a live audio feed of the service, allowing you to care for your little ones without missing the preaching of God's Word.
              </span>
            </li>
            <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">
                <strong>Children's Church (All Ages Above Nursery):</strong> Our Children's Church provides a specialized environment for children to learn at their level during our main services. 
              </span>
            </li>
          </ul>
          
          <p class="text-gray-700 mb-6 text-lg">
            All our children's ministry volunteers undergo background checks and are trained to provide a safe, nurturing environment.
          </p>
          
          <Button href="/ministries/childrens-ministry">
            Learn More About Children's Ministry
          </Button>
        </div>
        
        <div>
          <img 
            src="/uploads/CMB_6447.webp" 
            alt="Children at our church" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- Location & Directions -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Location & Directions</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
        <div class="map-wrapper shadow-md h-full">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3185.499213577961!2d-82.51908692377022!3d37.02174175517928!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x885ab55df0eb69a3%3A0x1a713edb43f314b8!2sLiving%20Waters%20Independent%20Baptist%20Church!5e0!3m2!1sen!2sus!4v1770324991652!5m2!1sen!2sus" 
            width="600" 
            height="450" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        
        <div class="h-full">
          <div class="bg-white p-8 rounded-lg shadow-md h-full">
            
           <h3 class="text-xl font-bold mb-4">Church Address</h3>
            <address class="not-italic mb-6 text-gray-700">
              <p class="text-lg">7561 Duncan Gap Rd.</p>
              <p class="text-lg">Wise, VA 24293</p>
            </address>
            <p class="text-gray-700 mb-6">
              We are located about 10 minutes from downtown Wise. Upon arrival, you will see our "Living Waters Independent Baptist Church" sign in the church yard. 
            </p>
            
            <h4 class="text-lg font-bold mb-2">Parking Information</h4>
            <p class="text-gray-700 mb-6">
              We have plenty of gravel parking beside the church. You are welcome to drive up to the front door to drop off your passengers under the awning.
            </p>
                        
              <Button href="https://maps.google.com/?q=Living+Waters+Independent+Baptist+Church/@37.0217375,-82.5190869,17z" target="_blank" variant="primary">
                Get Directions
              </Button>
            

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- FAQ Section -->
  <section id="faq" class="py-16 bg-gray-50">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Frequently Asked Questions</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Answers to common questions from first-time visitors
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="space-y-4">
        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">What do I do when I arrive?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            Upon arrival, you'll be greeted by our friendly door greeters who will welcome you and answer any questions you may have. Feel free to find a seat anywhere in the sanctuary - we want you to feel at home!
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">Will I be asked to stand up or introduce myself?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            No, we won't single you out or ask you to stand up. We want you to feel comfortable, not put on the spot. We do have a welcome card you can fill out if you'd like to share your information with us.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">Do you have facilities for nursing mothers?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            Yes, we have a comfortable, private nursing mothers' room adjacent to the nursery. It's equipped with changing facilities, comfortable seating, and a live audio feed of the service.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">How do I get connected beyond Sunday services?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            The best way to get connected is through our small groups and ministry teams. We have men and women's ministries that do not require membership to attend. 
          </p>
        </details>
      </div>
    </div>
  </div>
</section>
  
  <!-- Plan Your Visit CTA -->
  <section id="volunteer" class="py-20 bg-cover bg-center text-white"
    style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(/uploads/visit-us.webp"
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Ready to Visit?</h2>
        <p class="text-xl mb-8">
          We look forward to meeting you. If you have any questions before your visit, please don't hesitate to contact us.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/contact" variant="primary" size="lg">
            Contact Us
          </Button>
          
          <Button href="https://maps.google.com/?q=Living+Waters+Independent+Baptist+Church/@37.0217375,-82.5190869,17z" target="_blank" variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
            Get Directions
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>